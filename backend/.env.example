# Aftercall environment — copy to .env and fill in. NEVER commit .env (docs/TOS.md §3).

# --- Dial (the spine) ---
# Get from https://getdial.ai (Bearer token). Leaving this blank runs DRY_RUN
# (no real calls/SMS) so you can build and demo the full flow without a key.
DIAL_API_KEY=
DIAL_BASE_URL=https://getdial.ai/api/v1
# Provisioned number id, e.g. pn_123
DIAL_FROM_NUMBER_ID=
# HMAC secret Dial signs webhooks with (optional locally; verified if set).
DIAL_WEBHOOK_SECRET=

# Public URL where Dial reaches /webhooks/dial (e.g. an ngrok https URL).
PUBLIC_BASE_URL=

# Tuned to Dial's real rate limit (VERIFY LIVE in hour 0).
MAX_CONCURRENT_CALLS=5
# UNREACHED retry policy
MAX_ATTEMPTS=2
RETRY_DELAY_SECONDS=600

# --- Stripe (test mode ONLY — sk_test_...; a live key is refused at startup) ---
STRIPE_SECRET_KEY=
STRIPE_RELIEF_POOL_CENTS=200000
STRIPE_MAX_GRANT_CENTS=20000
USAGE_PRICE_CENTS_PER_PERSON=12

# --- Local ---
AFTERCALL_DB=aftercall.db
